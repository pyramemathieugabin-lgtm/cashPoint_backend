generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  admin
  operator
}

enum Operator {
  YAS
  AIRTEL
  ORANGE
}

enum OperationType {
  DEPOT
  RETRAIT
  TRANSFERT
  CREDIT
}

model User {
  id                         String      @id @default(uuid())
  name                       String
  email                      String      @unique
  passwordHash               String
  role                       Role        @default(operator)
  cashBox                    CashBox?
  balances                   OperatorBalance[]
  operations                 Operation[]
  tariffs                    Tariff[]
  createdAt                  DateTime    @default(now())
  updatedAt                  DateTime    @updatedAt
}

model CashBox {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cashBalance   Float    @default(0)
  mobileBalance Float    @default(0)
  dayStarted    Boolean  @default(false)
  dayOpenedAt   DateTime?
  dayClosedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model OperatorBalance {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  operator      Operator
  cashBalance   Float    @default(0)
  mobileBalance Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, operator])
}

model Tariff {
  id            String        @id @default(uuid())
  userId        String?
  user          User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  operator      Operator
  operationType OperationType
  minAmount     Float         @default(0)
  maxAmount     Float         @default(999999999)
  operatorFee   Float         @default(0)
  personalFee   Float         @default(0)
  gainCumule    Float         @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@unique([userId, operator, operationType, minAmount, maxAmount])
}

model Operation {
  id            String        @id @default(uuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  externalId    String?       @unique
  reference     String?
  referenceEditCount Int      @default(0)
  kind          String        @default("TRANSACTION")
  amount        Float
  operationType OperationType
  operator      Operator
  customerPhone String?
  customerName  String?
  includeWithdrawalFeeForTransfer Boolean @default(false)
  operatorFee   Float         @default(0)
  personalFee   Float         @default(0)
  clientFee     Float
  gain          Float
  totalFee      Float
  isCancelled   Boolean       @default(false)
  cancelledAt   DateTime?
  initialCashBalance Float?
  initialMobileBalance Float?
  finalCashBalance Float?
  finalMobileBalance Float?
  reapproCashAmount Float?
  reapproMobileAmount Float?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}
